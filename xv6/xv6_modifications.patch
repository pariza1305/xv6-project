+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+
+// A simple CPU-bound task to make the processes run for a while
+void cpu_intensive_task()
+{
+  // Use a volatile variable to prevent the compiler from optimizing the loop away
+  for (volatile int i = 0; i < 1000000000; i++) {}
+}
+
+int
+main(int argc, char *argv[])
+{
+  int num_children = 5;
+  int total_wtime = 0;
+  int total_rtime = 0;
+
+  printf("Starting scheduler test with %d children...\n", num_children);
+
+  for (int i = 0; i < num_children; i++) {
+    int pid = fork();
+    if (pid < 0) {
+      printf("fork failed\n");
+      exit(1);
+    }
+    if (pid == 0) { // Child process
+      printf("Child %d starting CPU task.\n", getpid());
+      cpu_intensive_task();
+      exit(0);
+    }
+  }
+
+  // Parent process waits for all children and collects stats
+  for (int i = 0; i < num_children; i++) {
+    int wtime, rtime;
+    // This uses the wait_stat syscall you implemented
+    int child_pid = wait_stat(&wtime, &rtime);
+    if (child_pid != -1) {
+      printf("Child PID %d: Wait Time = %d, Run Time = %d\n", child_pid, wtime, rtime);
+      total_wtime += wtime;
+      total_rtime += rtime;
+    }
+  }
+
+  printf("\n--- Final Results ---\n");
+  printf("Average Wait Time: %d ticks\n", total_wtime / num_children);
+  printf("Average Run Time: %d ticks\n", total_rtime / num_children);
+
+  exit(0);
+}
